# Telegram Bot Token — obtain from @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# Comma-separated list of allowed Telegram chat IDs
# Leave empty to allow all users (not recommended for production)
ALLOWED_CHAT_IDS=

# Server port for REST API
API_PORT=3000

# Bearer token for REST API authentication
# Leave empty to disable auth (not recommended for production)
API_TOKEN=

# SQLite database file path
DB_PATH=./data/receipt-tracker.db

# Directory for storing receipt images
IMAGE_DIR=./data/images

# OCR engine: "tesseractjs" | "native"
# "native" requires tesseract-ocr package installed on the system
# "native" is 10-14x faster on Raspberry Pi and strongly recommended
OCR_ENGINE=native

# Tesseract language data (lav = Latvian, eng = English)
# For native engine: install with `sudo apt install tesseract-ocr-lav`
TESSERACT_LANG=lav+eng

# Maximum image width for OCR preprocessing (pixels)
# Lower = faster OCR, 800 is optimal for receipts
MAX_IMAGE_WIDTH=800

# Maximum file size for incoming images (bytes)
MAX_IMAGE_SIZE=3145728

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Deduplication similarity threshold (0.0 - 1.0)
# Products with similarity above this are considered the same
SIMILARITY_THRESHOLD=0.80
